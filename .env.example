# Firebase (WLHORIZON) — Priority 1 data source
# Credentials from the WLHORIZON Firebase project (service account)
# FIREBASE_PROJECT_ID=your-project-id
# FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project-id.iam.gserviceaccount.com
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
# FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com
# WL_APP_ID=app_cfb23cce-7aa1-475f-b5de-804f441b865e

# Firebase Client SDK (browser-side, exposed to the client)
# NEXT_PUBLIC_FIREBASE_API_KEY=AIza...
# NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
# NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
# NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com
# NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=123456789
# NEXT_PUBLIC_FIREBASE_APP_ID=1:123456789:web:abcdef

# WLHORIZON app ID (exposed to client for Cloud Function calls)
# NEXT_PUBLIC_WL_APP_ID=app_cfb23cce-7aa1-475f-b5de-804f441b865e

# Stripe — payment processing
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...

# Google Analytics 4 (optional)
# NEXT_PUBLIC_GA4_ID=G-XXXXXXXXXX

# Directus CMS — Priority 2 data source (fallback when Firebase is not configured)
NEXT_PUBLIC_DIRECTUS_URL=http://localhost:8055

# Optional: static API token (only needed if Public role is not configured)
# DIRECTUS_STATIC_TOKEN=your-token-here
